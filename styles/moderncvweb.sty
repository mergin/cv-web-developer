\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{moderncvweb}[2026/04/20 Minimal web developer CV theme]

\RequirePackage[a4paper,margin=1.55cm]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage[sfdefault]{roboto}
\RequirePackage{microtype}
\RequirePackage[table]{xcolor}
\RequirePackage{array}
\RequirePackage{parskip}
\RequirePackage{enumitem}
\RequirePackage{tabularx}
\RequirePackage{tikz}
\RequirePackage{titlesec}
\RequirePackage{hyperref}
\RequirePackage{ragged2e}
\RequirePackage{paracol}

\newif\ifcwhasicons
\IfFileExists{fontawesome5.sty}{%
  \RequirePackage{fontawesome5}
  \cwhasiconstrue
}{%
  \cwhasiconsfalse
}

\definecolor{accent}{HTML}{2F2F32}
\definecolor{ink}{HTML}{222326}
\definecolor{muted}{HTML}{68696D}
\definecolor{line}{HTML}{BDBEC2}
\definecolor{panel}{HTML}{F2F2F4}
\color{ink}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\tabcolsep}{0pt}
\urlstyle{same}
\hypersetup{colorlinks=true,urlcolor=ink,linkcolor=ink}

\newlength{\cventryleftwidth}
\newlength{\cventryrightwidth}
\newlength{\cventrygap}
\setlength{\cventryleftwidth}{0.36\linewidth}
\setlength{\cventryrightwidth}{0.61\linewidth}
\setlength{\cventrygap}{0.03\linewidth}

\titleformat{\section}
  {\normalfont\large\bfseries\color{ink}}
  {}
  {0em}
  {\MakeUppercase}
  [\vspace{-0.28em}{\color{ink}\rule{1.8cm}{0.8pt}}]
\titlespacing*{\section}{0pt}{0.75em}{0.1em}

\setlist[itemize]{leftmargin=1.1em,itemsep=0.15em,topsep=0.15em}

\newcommand{\smallmuted}[1]{{\small\color{muted}#1}}
\newcommand{\caps}[1]{{\footnotesize\bfseries\MakeUppercase{#1}}}

\newcommand{\cvPhoneIcon}{\ifcwhasicons\faPhone\else\textbf{P}\fi}
\newcommand{\cvMailIcon}{\ifcwhasicons\faEnvelope\else\textbf{E}\fi}
\newcommand{\cvMapIcon}{\ifcwhasicons\faMapMarker*\else\textbf{A}\fi}
\newcommand{\cvGitHubIcon}{\ifcwhasicons\faGithub\else\textbf{G}\fi}

\newcommand{\topruleline}{\noindent\color{ink}\rule{\linewidth}{1.2pt}\par}

\newcommand{\panelbox}[1]{%
  \noindent
  \setlength{\fboxsep}{12pt}%
  \fcolorbox{line}{panel}{%
    \begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}
      #1
    \end{minipage}
  }%
}

\newcommand{\contactpill}[3]{%
  \setlength{\fboxsep}{6pt}%
  \colorbox{white}{\small\href{#3}{#1\enspace #2}}%
}

\newcommand{\cvskill}[2]{%
  \begin{tabularx}{\linewidth}{@{}Xr@{}}
    \textbf{#1} &
    \begin{tikzpicture}[baseline=-0.6ex]
      \fill[line] (0,0) rectangle (2.1,0.085);
      \fill[ink] (0,0) rectangle ({(#2/5)*2.1},0.085);
    \end{tikzpicture}
  \end{tabularx}\par\vspace{0.28em}
}

\newcommand{\cventry}[4]{%
  \begin{minipage}[t]{\cventryleftwidth}
    {\bfseries #2}\par
    \smallmuted{#4}\par
  \end{minipage}\hfill
  \begin{minipage}[t]{\cventryrightwidth}
    {\bfseries\MakeUppercase{#1}}\par
    \smallmuted{#3}\par
  \end{minipage}\par
  \vspace{0.1em}
}

\newcommand{\projectentry}[3]{%
  {\bfseries\MakeUppercase{#1}}\hfill{\smallmuted{#2}}\par
  {\small #3}\par
  \vspace{0.25em}
}

\newcommand{\letterrecipient}[4]{%
  {\bfseries #1}\par
  \smallmuted{#2}\par
  \smallmuted{#3}\par
  \smallmuted{#4}\par
}

\newcommand{\entrydetail}[1]{{\small #1\par\vspace{0.5em}}}
