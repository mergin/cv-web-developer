\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{moderncvweb}[2026/04/20 Minimal web developer CV theme]

% Page geometry and font configuration.
\RequirePackage[a4paper,margin=1.55cm]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
% Use a standard sans family that is broadly available in TeX distributions.
\RequirePackage{lmodern}
\renewcommand{\familydefault}{\sfdefault}

% General typography and layout helpers.
\RequirePackage{microtype}
\RequirePackage[table]{xcolor}
\RequirePackage{array}
\RequirePackage{parskip}
\RequirePackage{enumitem}
\RequirePackage{tabularx}
\RequirePackage{tikz}
\RequirePackage{titlesec}
\RequirePackage{hyperref}
\RequirePackage{ragged2e}
\RequirePackage{paracol}

% Optional icon support. When Font Awesome is unavailable, the theme falls back
% to plain text markers so the documents still compile.
\newif\ifcwhasicons
\IfFileExists{fontawesome5.sty}{%
  \RequirePackage{fontawesome5}
  \cwhasiconstrue
}{%
  \cwhasiconsfalse
}

% Shared visual palette for headings, body text, dividers, and panels.
\definecolor{accent}{HTML}{2F2F32}
\definecolor{ink}{HTML}{222326}
\definecolor{muted}{HTML}{68696D}
\definecolor{line}{HTML}{BDBEC2}
\definecolor{panel}{HTML}{F2F2F4}
\color{ink}

% Global document defaults for the clean CV layout.
\pagestyle{empty}
\setlength{\parindent}{0pt}
\setlength{\tabcolsep}{0pt}
\emergencystretch=0.8em
\urlstyle{same}
\hypersetup{colorlinks=true,urlcolor=ink,linkcolor=ink}

% The CV entry layout uses widths derived from the local column linewidth.

% Section headings use uppercase labels with a short underline accent.
% A full-width muted rule is drawn above each section to visually separate content blocks.
\titleformat{\section}
  {\normalfont\large\bfseries\color{ink}}
  {}
  {0em}
  % {{\color{line}\rule{\linewidth}{0.55pt}}\vspace{0.3em}\MakeUppercase}
  {\MakeUppercase}
  [\vspace{-1.0em}{\color{ink}\rule{1.8cm}{0.8pt}}]
\titlespacing*{\section}{0pt}{0.75em}{0.75em}

% Compact bullet spacing better suited for resume-style content density.
\setlist[itemize]{leftmargin=1.1em,itemsep=0.15em,topsep=0.15em}

% Small muted helper for dates, locations, and supporting metadata.
\newcommand{\smallmuted}[1]{{\small\color{muted}#1}}

% Uppercase helper for small labels and pill-style headings.
\newcommand{\caps}[1]{{\footnotesize\bfseries\MakeUppercase{#1}}}

% Contact icons with text fallbacks for environments without Font Awesome.
\newcommand{\cvPhoneIcon}{\ifcwhasicons\faPhone\else\textbf{P}\fi}
\newcommand{\cvMailIcon}{\ifcwhasicons\faEnvelope\else\textbf{E}\fi}
\newcommand{\cvMapIcon}{\ifcwhasicons\faMapMarker*\else\textbf{A}\fi}
\newcommand{\cvGitHubIcon}{\ifcwhasicons\faGithub\else\textbf{G}\fi}

% Full-width rule used above the profile header.
\newcommand{\topruleline}{\noindent\color{ink}\rule{\linewidth}{1.2pt}\par}

% Framed content box used for summary or highlighted content blocks.
\newcommand{\panelbox}[1]{%
  \noindent
  \setlength{\fboxsep}{12pt}%
  \fcolorbox{line}{panel}{%
    \begin{minipage}{\dimexpr\linewidth-2\fboxsep-2\fboxrule\relax}
      #1
    \end{minipage}
  }%
}

% Small inline chip for optional contact or metadata links.
\newcommand{\contactpill}[3]{%
  \setlength{\fboxsep}{6pt}%
  \colorbox{white}{\small\href{#3}{#1\enspace #2}}%
}

% Skill row with a text label and a minimalist horizontal proficiency bar.
\newcommand{\cvskill}[2]{%
  \noindent%
  \parbox[t]{0.73\linewidth}{\RaggedRight\textbf{#1}}%
  \hfill%
  \begin{tikzpicture}[baseline=-0.6ex]%
    % Background track.
    \fill[line] (0,0) rectangle (2.1,0.085);%
    % Filled portion scaled from a 1-5 rating.
    \fill[ink] (0,0) rectangle ({(#2/5)*2.1},0.085);%
  \end{tikzpicture}%
  \par\vspace{0.28em}
}

% Standard two-column CV entry.
% #1 role/title, #2 company or institution, #3 date/location line, #4 support line.
\newcommand{\cventry}[4]{%
  \noindent%
  \begin{minipage}[t]{0.39\linewidth}%
    \vspace{0pt}%
    \RaggedRight%
    {\bfseries #2}\par\smallmuted{#4}%
  \end{minipage}\hfill%
  \begin{minipage}[t]{0.56\linewidth}%
    \vspace{0pt}%
    \RaggedRight%
    {\bfseries\MakeUppercase{#1}}\par\smallmuted{#3}%
  \end{minipage}\par%
  \vspace{0.1em}%
}

% Project entry with project name, tools, and short description.
\newcommand{\projectentry}[3]{%
  {\bfseries\MakeUppercase{#1}}\hfill{\smallmuted{#2}}\par
  {\small #3}\par
  \vspace{0.25em}
}

% Recipient block for the cover letter heading.
\newcommand{\letterrecipient}[4]{%
  {\bfseries #1}\par
  \smallmuted{#2}\par
  \smallmuted{#3}\par
  \smallmuted{#4}\par
}

% Small body-text helper used for standalone detail paragraphs.
\newcommand{\entrydetail}[1]{{\small #1\par\vspace{1em}}}
